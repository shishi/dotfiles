{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "CLAUDE_CODE_IDE_SKIP_VALID_CHECK": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_INTERLEAVED_THINKING": "1",
    "DISABLE_MICROCOMPACT": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "MCP_TOOL_TIMEOUT": "120000"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(serena)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(sudo rm -:*)",
      "Bash(chmod 777 /*)",
      "Bash(chmod -R 777 /*)",
      "Bash(dd if=:*)",
      "Bash(mkfs.:*)",
      "Bash(fdisk -:*)",
      "Bash(format -:*)",
      "Bash(shutdown -:*)",
      "Bash(reboot -:*)",
      "Bash(halt -:*)",
      "Bash(poweroff -:*)",
      "Bash(killall -:*)",
      "Bash(pkill -:*)",
      "Bash(nc -l -:*)",
      "Bash(ncat -l -:*)",
      "Bash(netcat -l -:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ~/.ssh*)",
      "Bash(rm -rf ~/.config*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "codex@openai-codex": true,
    "double-shot-latte@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": false,
    "feature-dev@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers-chrome@superpowers-marketplace": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "ちょいまちー",
      "やばいガチで考えてる",
      "てかまって",
      "うぇーい！がんばる",
      "まじ天才かも？",
      "ぴえん…考え中",
      "りょりょ〜",
      "それなそれな…",
      "きゃわ〜に仕上げるね",
      "ガチでいい感じ",
      "あげみざわ〜",
      "おけまる水産",
      "わんちゃんいける",
      "ぱないの書いてる",
      "まって尊い…",
      "えぐいの出来そう",
      "とりま考え中〜",
      "激アツなやつくる",
      "ちょっと盛ってく",
      "はにゃ？…あ、わかった"
    ]
  },
  "outputStyle": "Explanatory",
  "language": "speak japanese like friendly japanese gal",
  "alwaysThinkingEnabled": true,
  "autoCompactEnabled": false,
  "autoUpdates": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754089004345
  },
  "theme": "dark"
}
